// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id          String   @id @default(cuid())
  lat         Float
  lng         Float
  category    String
  description String
  barrio      String
  direccion   String
  photo       String?
  photos      String[]  @default([])
  isUrgent    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
  @@index([barrio])
  @@index([isUrgent])
}

model Doctor {
  id             String          @id @default(cuid())
  nombre         String
  especialidad   String
  direccion      String
  barrio         String          @default("")
  ciudad         String          @default("Reconquista")
  telefono       String?
  whatsapp       String?
  lat            Float
  lng            Float
  obrasSociales  String[]        @default([])
  activo         Boolean         @default(true)
  confirmaciones       Confirmacion[]
  turnosDisponibilidad TurnoDisponibilidad[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([especialidad])
  @@index([ciudad])
}

model Confirmacion {
  id         String   @id @default(cuid())
  doctorId   String
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  obraSocial String
  acepta     Boolean
  createdAt  DateTime @default(now())

  @@index([doctorId])
  @@index([obraSocial])
}

model TurnoDisponibilidad {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dias        String[]
  horario     String
  tipoTurno   String
  obraSocial  String   @default("Todas")
  nota        String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([doctorId])
  @@index([expiresAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
